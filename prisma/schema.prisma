generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  connection_limit = 30
}


model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  roleId        Int
  status        String   @default("active")
  organizerStatus String @default("none")
  tickets       Ticket[]
  scanLogs      ScanLog[] @relation("UserScanLogs")
  validations   TicketValidation[] @relation("Validator")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role             Role                @relation(fields: [roleId], references: [id])
  userRoles        UserRole[]
  controllerEvents EventController[]
  sessions         Session[]
  accounts         Account[]
  organizerProfile Organizer_profile?
  events           Event[]
  organizerRequests OrganizerRequest[]
  reviewedRequests  OrganizerRequest[] @relation("OrganizerRequestReviewer")
  favorites         Favorite[]
  eventViews        EventView[]
}

model Role {
  id    Int    @id @default(autoincrement())
  role  String @unique
  users User[]
  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model Permission {
  id          String @id @default(cuid())
  name        String @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId String

  role        Role       @relation(fields: [roleId], references: [id])
  permission  Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String   @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // auth locale + oauth
  password              String?
  accessToken           String?  @db.Text
  refreshToken          String?  @db.Text
  idToken               String?  @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Organizer_profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String   @db.Text
  phone       String?
  description String   @db.Text
  website     String?  // ajout du site web
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Ville {
  id        String   @id @default(cuid())
  nomVille  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  villeId     String
  categoryId  String
  title       String
  description String   @db.Text

  details     String  @db.Text
  maxUsage    Int @default(1)
  location    String
  eventDate   DateTime
  startDate   String
  endDate     String?
  price       Decimal?  @db.Decimal(10,2)
  priceType   PriceType @default(FREE)
  status      EventStatus @default(DRAFT)
  entryMode EntryMode @default(PUBLIC)
  views       Int       @default(0)
  privilege   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ville      Ville            @relation(fields: [villeId], references: [id], onDelete: Cascade)
  category   Categorie        @relation(fields: [categoryId], references:[id], onDelete: Cascade)
  controllers EventController[]
  tickets     Ticket[]
  images      EventImage[]
  favorites   Favorite[]
  viewsRelation EventView[]
}

model EventImage {
  id          String @id @default(cuid())
  url         String
  eventId     String
  Event       Event  @relation(fields: [eventId], references:[id], onDelete: Cascade)
}

model Categorie {
  id    String @id @default(cuid())
  name  String @unique

  events Event[]
}

model Newsletter {
  id          String @id @default(cuid())
  email       String @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

//table pour reconnaitre les organisateurs ont effectués de demande
model OrganizerRequest {
  id          String                  @id @default(cuid())
  userId      String
  status      OrganizerRequestStatus  @default(pending)
  comment     String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer    User?                   @relation("OrganizerRequestReviewer", fields: [reviewedBy], references: [id])

  @@map("organizer_requests")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) // empêche les doublons
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model EventView {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?   // null si visiteur non connecté
  visitorId String?   // pour visiteurs anonymes
  createdAt DateTime @default(now())
  source    TrafficSource? 
  country   String?
  city      String?
  device String?
  referrer String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([createdAt])
  @@index([eventId, createdAt])
}

model Ticket {
  id         String   @id @default(cuid())
  token      String   @unique @db.Text
  status     TicketStatus @default(ACTIVE)
  usedCount  Int      @default(0)
  expiresAt  DateTime

  eventId    String
  userId     String

  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  validations TicketValidation[]
  scanLogs    ScanLog[]

  createdAt DateTime @default(now())
  @@index([token])
}

model TicketValidation {
  id          String   @id @default(cuid())
  validatedAt DateTime @default(now())

  ticketId    String
  validatedBy String

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  validator   User     @relation("Validator", fields: [validatedBy], references: [id])
}

model ScanLog {
  id         String   @id @default(cuid())
  scanResult ScanResult
  createdAt  DateTime @default(now())

  ticketId   String
  scannedBy  String

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  scanner    User     @relation("UserScanLogs", fields: [scannedBy], references: [id])
  @@index([ticketId])
}

model EventController {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    ControllerStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

enum TrafficSource {
  FACEBOOK
  WHATSAPP
  INSTAGRAM
  GOOGLE
  DIRECT
  PLATFORM
}

enum OrganizerRequestStatus {
  pending
  approved
  rejected
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum PriceType {
  FREE
  PAID
}

enum EntryMode {
  PUBLIC
  PRIVATE
}

enum TicketStatus {
  ACTIVE
  EXPIRED
  USED
}

enum ScanResult {
  VALID
  REFUSED
  EXPIRED
  INVALID
}

enum ControllerStatus {
  PENDING
  APPROVED
  REJECTED
}
